#include <iostream>
using namespace std;

int main()
{
   int age;
   cout << "Enter Age (1-120): ";
   cin >> age;
   
   while (age < 1 || age > 120){
       cout << "Invalid. Please enter a realistic age: ";
       cin >> age;
   }
   
   return 0;
}

