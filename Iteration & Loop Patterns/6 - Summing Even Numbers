#include <iostream>
using namespace std;

int main()
{
    // initialize variable 
 int sum = 0;
 // for loop starts at 2 and increaes by 2 each time for only even numbers 
 for (int i = 2; i <= 20; i += 2){
     sum += i; //adds to sum 
 }
 cout << "Sum is " << sum;
 
 
   return 0;
}

