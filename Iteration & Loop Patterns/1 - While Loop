#include <iostream>
using namespace std;

int main()
{
 // variables   
int total = 0;
int counter = 1;

// ask user to enter grades 
cout << "Enter 10 grades:" << endl;

// while loop runs until the counter is equal to 10
while (counter <= 10) {
    int grade;
    cin >> grade;
    total += grade;
    counter++;
}
// calcualtes average but convert to decimal first
double average =
static_cast<double>(total)/10;
cout << "Average: " << average;
    return 0;
}

