#include <iostream>
using namespace std;

int main()
{
   int count = 0; 
   
    for (int i = 0; i < 10; i++) 
       count++;
   cout << "Count: " << count << endl;
   
   int sum = 0; 
    
    for (int i = 1; i<= 5; i++ )
        sum += i;
   cout << "Sum: " << sum;
   
   return 0;
}

